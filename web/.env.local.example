# Server-only: never expose to the client. Use in Route Handlers / Server Actions only.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Login / office: same Postgres as Supabase (direct or pooler) + random secret for session cookie.
# DATABASE_URL=postgresql://postgres:PASSWORD@db.xxx.supabase.co:5432/postgres
# AUTH_SECRET=replace_with_a_random_string_at_least_32_chars_long

# Yandex OAuth (server-only)
# YANDEX_CLIENT_ID=...
# YANDEX_CLIENT_SECRET=...
# YANDEX_REDIRECT_URI=https://lab-career.ru/auth/callback

# SMTP для восстановления пароля (server-only).
# Провайдер: Unisender Go (РФ, транзакционный транспорт, есть бесплатный тариф).
# host — go1 или go2 в зависимости от того, где зарегистрирован кабинет.
# USER = user_id (или project_id) из кабинета, PASS = пароль из раздела "SMTP" кабинета.
# FROM должен быть на домене lab-career.ru, у которого в кабинете подтверждены SPF/DKIM.
# SMTP_HOST=smtp.go1.unisender.ru
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=your_user_id
# SMTP_PASS=your_smtp_password
# SMTP_FROM="CareerLab <no-reply@lab-career.ru>"
# MAIL_APP_NAME=CareerLab
