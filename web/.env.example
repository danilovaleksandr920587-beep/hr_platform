# Supabase (public — попадают в клиентский бандл)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Публичный URL сайта (для metadata, sitemap, magic link в проде)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Только сервер: не добавляйте в клиент. Нужен для админ-операций, не используется в текущем UI.
# SUPABASE_SERVICE_ROLE_KEY=
