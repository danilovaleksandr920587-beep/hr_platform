# Vercel: те же NEXT_PUBLIC_* нужны для Preview и Production (иначе preview-*.vercel.app без данных).
# Схема vacancies: root (корневая supabase/migrations) или web — по умолчанию пробуем root, затем web.
# NEXT_PUBLIC_VACANCIES_SCHEMA=root
# Supabase (public — попадают в клиентский бандл)
NEXT_PUBLIC_SUPABASE_URL=https://tetukoylasquueg.beget.app
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoiYW5vbiIsImlzcyI6InN1cGFiYXNlIiwiaWF0IjoxNzc2NjQzMjAwLCJleHAiOjE5MzQ0MDk2MDB9.5XEDypOTMio-_M7UcHZnocTFN65ckAwLhzvyS_qF7pA
# Публичный URL сайта (канонический домен; для metadata, sitemap и OAuth redirect)
NEXT_PUBLIC_SITE_URL=https://lab-career.ru

# OAuth Yandex (server-only)
# YANDEX_CLIENT_ID=...
# YANDEX_CLIENT_SECRET=...
# YANDEX_REDIRECT_URI=https://lab-career.ru/auth/callback

# Только сервер: не добавляйте в клиент. Нужен для админ-операций, не используется в текущем UI.
# SUPABASE_SERVICE_ROLE_KEY=

# Вход в кабинет (email + пароль): Postgres connection string и секрет для JWT (≥ 32 символов).
# DATABASE_URL=postgresql://postgres:PASSWORD@db.xxx.supabase.co:5432/postgres
# AUTH_SECRET=сгенерируйте_длинную_случайную_строку_минимум_32_символа

# SMTP для восстановления пароля (server-only).
# Провайдер: Unisender Go (РФ, транзакционный транспорт, есть бесплатный тариф).
# host — go1 или go2 в зависимости от кабинета; USER = user_id/project_id, PASS = пароль из раздела "SMTP".
# FROM обязан быть на домене lab-career.ru с подтверждёнными SPF/DKIM.
# SMTP_HOST=smtp.go1.unisender.ru
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=your_user_id
# SMTP_PASS=your_smtp_password
# SMTP_FROM="CareerLab <no-reply@lab-career.ru>"
# MAIL_APP_NAME=CareerLab
